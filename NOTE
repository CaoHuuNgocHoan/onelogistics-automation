## 📄 File 1: `data/test_data.py` — Chứa test data

```python
# data/test_data.py
# ==========================================
# TEST DATA - OneLogistics Login
# ==========================================
# ⚠️ Hoan: Thay bằng URL và credentials THẬT của QA environment
# ==========================================

# URL
BASE_URL = "https://onelogistics-qa.example.com"    # ← THAY URL THẬT
LOGIN_URL = f"{BASE_URL}/login"                       # ← THAY nếu URL login khác

# Valid credentials
VALID_USERNAME = "hoan.test@company.com"              # ← THAY username thật
VALID_PASSWORD = "YourPassword123"                    # ← THAY password thật

# Invalid credentials (dùng để test negative cases)
INVALID_USERNAME = "wrong@company.com"
INVALID_PASSWORD = "WrongPassword"
EMPTY_STRING = ""

# Expected values after login
DASHBOARD_URL_KEYWORD = "dashboard"                   # ← URL sau login chứa từ gì?
WELCOME_MESSAGE = "Welcome"                           # ← Message hiện sau login?
PAGE_TITLE_AFTER_LOGIN = "OneLogistics"               # ← Title page sau login?

# Error messages
LOGIN_ERROR_MESSAGE = "Invalid username or password"  # ← Message lỗi khi login sai?
REQUIRED_FIELD_MESSAGE = "This field is required"     # ← Message khi để trống?

